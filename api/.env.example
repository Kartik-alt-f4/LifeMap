# ── Required ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here
CRON_SECRET=any-random-string-you-choose

# ── Discord (optional — skip if not using) ────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL_ID=

# ── Auto-set ──────────────────────────────────────────────────────────────────
# NODE_ENV is set by Render automatically in production
# PORT is read from config/server.json (default: 3001)
